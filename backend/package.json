{
  "name": "incident-response-backend",
  "version": "1.0.0",
  "description": "Express + Socket.IO backend for Incident Response Simulator",
  "type": "module",
  "main": "src/server.mjs",
  "scripts": {
    "start": "node --env-file=.env src/server.mjs",
    "dev": "node --env-file=.env --watch src/server.mjs",
    "postinstall": "node -e \"const fs=require('fs');if(!fs.existsSync('.env')&&fs.existsSync('.env.example'))fs.copyFileSync('.env.example','.env');\"",
    "lint": "echo \"Add ESLint locally as needed\" && exit 0",
    "test": "node test/server.test.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "morgan": "^1.10.0",
    "nanoid": "^5.0.0",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "socket.io-client": "^4.7.5"
  }
}
